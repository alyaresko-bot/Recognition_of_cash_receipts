TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_FILE=credentials.json
OPENAI_API_KEY=your_openai_api_key_here
# Основная модель для распознавания фото чека
OPENAI_VISION_MODEL=gpt-4o-mini
# Необязательно: если указать, перекроет OPENAI_VISION_MODEL
# OPENAI_MODEL=gpt-4o-mini

# Имя листа для чеков (по умолчанию Sheet1, для русской локали часто Лист1)
GOOGLE_SHEETS_SHEET_NAME=Sheet1
# Имя листа для позиций товаров (по умолчанию Товар)
GOOGLE_SHEETS_ITEMS_SHEET_NAME=Товар

# Состояние загрузки чека: sqlite (по умолчанию) или redis
# RECEIPT_STATE_BACKEND=sqlite
# RECEIPT_STATE_SQLITE_PATH=receipt_state.db
# RECEIPT_STATE_BACKEND=redis
# REDIS_URL=redis://localhost:6379/0

# Предобработка фото перед распознаванием (EXIF-поворот, лимит размера, обрезка полей)
# RECEIPT_PREPROCESS_ENABLED=1
# RECEIPT_PREPROCESS_MAX_SIDE=3000

# Обрезка полей по контенту (эвристика).
# Если LLM путает строки/колонки — лучше отключить (0).
# RECEIPT_PREPROCESS_CROP_ENABLED=0

# Чтение фискального QR перед vision (QReader при установке, иначе OpenCV). 0 — отключить.
# RECEIPT_QR_ENABLED=1
